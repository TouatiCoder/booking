rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Is the user logged in?
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Does the logged in user's email match the requested email?
    function isOwner(email) {
      return isSignedIn() && (request.auth.token.email == email || request.auth.uid == email);
    }

    // Helper: Is the caller an administrator?
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@zellige.com' || 
        get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role == 'admin'
      );
    }

    // ==========================================
    // 1. USERS COLLECTION
    // ==========================================
    match /users/{email} {
      allow read: if isSignedIn();
      allow write: if isOwner(email) || isAdmin();
    }

    // ==========================================
    // 2. PROPERTIES COLLECTION
    // ==========================================
    match /properties/{propertyId} {
      // Anyone can browse properties
      allow read: if true;
      
      // Hosts can write their own properties, and Admins can write any
      allow create, update: if isAdmin() || (
        isSignedIn() && 
        request.resource.data.hostEmail == request.auth.token.email
      );
      
      allow delete: if isAdmin() || (
        isSignedIn() && 
        resource.data.hostEmail == request.auth.token.email
      );
    }

    // ==========================================
    // 3. RESERVATIONS COLLECTION
    // ==========================================
    match /reservations/{reservationId} {
      allow read: if isAdmin() || (
        isSignedIn() && (
          resource.data.userEmail == request.auth.token.email ||
          get(/databases/$(database)/documents/properties/$(resource.data.propertyId)).data.hostEmail == request.auth.token.email
        )
      );
      
      allow write: if isAdmin() || (
        isSignedIn() && 
        request.resource.data.userEmail == request.auth.token.email
      );
    }

    // ==========================================
    // 4. FAVORITES COLLECTION
    // ==========================================
    match /favorites/{favoriteId} {
      allow read, write: if isSignedIn() && (
        resource.data.userEmail == request.auth.token.email || 
        request.resource.data.userEmail == request.auth.token.email
      );
    }

    // ==========================================
    // 5. SUBSCRIPTIONS COLLECTION
    // ==========================================
    match /subscriptions/{subscriptionId} {
      allow read: if isSignedIn() && (
        resource.data.hostEmail == request.auth.token.email || 
        isAdmin()
      );
      
      allow write: if isAdmin() || (
        isSignedIn() && 
        request.resource.data.hostEmail == request.auth.token.email
      );
    }

    // ==========================================
    // 6. NOTIFICATIONS COLLECTION
    // ==========================================
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.userEmail == request.auth.token.email;
      allow write: if isAdmin() || (isSignedIn() && request.resource.data.userEmail == request.auth.token.email);
    }

    // ==========================================
    // 7. CITIES COLLECTION
    // ==========================================
    match /cities/{cityId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
